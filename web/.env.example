# --- Auth (Auth.js v5) -------------------------------------------------------
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-me"
# Local dev credentials provider (M0). Replace with real OAuth/email providers before deploy.
AUTH_DEV_EMAIL="dev@climateprep.local"
AUTH_DEV_PASSWORD="climateprep"

# --- Compute engine (spec §3.5 swappable contract) ---------------------------
# Local FastAPI service now; a Vercel Python function or standalone service later.
ENGINE_URL="http://localhost:8000"

# --- Provenance --------------------------------------------------------------
# In production Vercel injects this from the git SHA/tag. Stamped into results/exports.
APP_VERSION="0.0.0-dev"

# --- Local storage (optional overrides) --------------------------------------
# On Windows, keep PGlite OUT of a OneDrive/Dropbox-synced folder — background
# sync corrupts file-backed databases. Point it at a local, non-synced path:
# PGLITE_DATA_DIR="C:/Users/<you>/AppData/Local/climatePrep/pgdata"
# BLOB_LOCAL_DIR=".storage/blob"

# --- Deploy (unused locally; documented for the swap) ------------------------
# DATABASE_URL=            # Neon / Vercel Postgres
# BLOB_READ_WRITE_TOKEN=   # Vercel Blob
# KV_REST_API_URL=         # Upstash / Vercel KV
# KV_REST_API_TOKEN=
# QSTASH_TOKEN=            # Upstash QStash
# SENTRY_DSN=
